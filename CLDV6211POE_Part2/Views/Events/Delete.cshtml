@model CLDV6211POE_Part2.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Delete Event</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Events</a>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="text-danger me-2" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.9.9 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
            </svg>
            <h5 class="text-danger mb-0">Are you sure you want to delete this event?</h5>
        </div>
        <hr />
        <div class="row">
            <div class="col-md-8">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("MMM dd, yyyy HH:mm")</dd>
                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToString("MMM dd, yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="col-md-4 text-center">
                <img src="@(Model.ImageUrl.Contains("placeholder") ? Model.ImageUrl : "/images/" + System.IO.Path.GetFileName(new Uri(Model.ImageUrl).LocalPath))" alt="@Model.Name" class="img-fluid rounded" style="max-height:150px;object-fit:cover;" />
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <form asp-action="Delete" class="d-inline">
        <input type="hidden" asp-for="EventId" />
        <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    </form>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</div>
