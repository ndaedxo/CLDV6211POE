@model CLDV6211POE_Part2.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Event Details</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Events</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("MMM dd, yyyy HH:mm")</dd>
                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToString("MMM dd, yyyy HH:mm")</dd>
                    <dt class="col-sm-4">Duration</dt>
                    <dd class="col-sm-8">
                        @{
                            var duration = Model.EndDate - Model.StartDate;
                            <span class="badge bg-info">@($"{duration.Days}d {duration.Hours}h {duration.Minutes}m")</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="col-md-6 text-center">
                <img src="@(Model.ImageUrl.Contains("placeholder") ? Model.ImageUrl : "/images/" + System.IO.Path.GetFileName(new Uri(Model.ImageUrl).LocalPath))" alt="@Model.Name" class="img-fluid rounded" style="max-height:300px;object-fit:cover;" />
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.EventId" class="btn btn-danger">Delete</a>
</div>
