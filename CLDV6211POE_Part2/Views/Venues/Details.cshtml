@model CLDV6211POE_Part2.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Venue Details</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Venues</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Location)</dd>
                    <dt class="col-sm-4">Capacity</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Html.DisplayFor(model => model.Capacity)</span></dd>
                </dl>
            </div>
            <div class="col-md-6 text-center">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height:300px;object-fit:cover;" />
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.VenueId" class="btn btn-danger">Delete</a>
</div>
