@model CLDV6211POE_Part2.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Delete Booking</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Bookings</a>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="text-danger me-2" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.9.9 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
            </svg>
            <h5 class="text-danger mb-0">Are you sure you want to delete this booking?</h5>
        </div>
        <hr />
        <dl class="row mb-0">
            <dt class="col-sm-3">Booking ID</dt>
            <dd class="col-sm-9"><span class="badge bg-primary">#@Model.BookingId</span></dd>
            <dt class="col-sm-3">Event</dt>
            <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.Event.Name)</strong></dd>
            <dt class="col-sm-3">Venue</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Venue.Name)</dd>
            <dt class="col-sm-3">Booking Date</dt>
            <dd class="col-sm-9">@Model.BookingDate.ToString("MMM dd, yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <form asp-action="Delete" class="d-inline">
        <input type="hidden" asp-for="BookingId" />
        <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    </form>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</div>
