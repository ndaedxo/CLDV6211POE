@model CLDV6211POE_Part2.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Create Booking</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Bookings</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="mb-3">
                        <label asp-for="EventId" class="form-label"></label>
                        <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId">
                            <option value="">-- Select Event --</option>
                        </select>
                        <span asp-validation-for="EventId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VenueId" class="form-label"></label>
                        <select asp-for="VenueId" class="form-control" asp-items="ViewBag.VenueId">
                            <option value="">-- Select Venue --</option>
                        </select>
                        <span asp-validation-for="VenueId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="BookingDate" class="form-label"></label>
                        <input asp-for="BookingDate" class="form-control" type="datetime-local" />
                        <span asp-validation-for="BookingDate" class="text-danger"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <input type="submit" value="Create Booking" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
            <div class="col-md-6">
                <div class="text-muted mt-4">
                    <h6>Booking Tips</h6>
                    <ul class="small">
                        <li>Select an event and venue to link them together</li>
                        <li>The booking date records when the reservation was made</li>
                        <li>Ensure the venue is available for the event date range</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
