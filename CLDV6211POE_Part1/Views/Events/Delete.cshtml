@model CLDV6211POE_Part1.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<h1>Delete Event</h1>

<h3>Are you sure you want to delete this event?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDate)</dd>
        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>
        <dt class="col-sm-3">Image</dt>
        <dd class="col-sm-9"><img src="@Model.ImageUrl" alt="@Model.Name" style="max-width:300px;" /></dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="EventId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
