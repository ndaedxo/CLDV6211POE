@model CLDV6211POE_Part1.Models.Venue

@{
    ViewData["Title"] = "Create Venue";
}

<h1>Create Venue</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Location" class="control-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Capacity" class="control-label"></label>
                <input asp-for="Capacity" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                <small class="d-block text-muted mt-2">
                    <strong>Suggested image services:</strong><br />
                    • <a href="https://picsum.photos" target="_blank">picsum.photos</a> - Use format: <code>https://picsum.photos/width/height</code> (e.g., 300/200)<br />
                    • <a href="https://placehold.co" target="_blank">placehold.co</a> - Use format: <code>https://placehold.co/widthxheight</code> (e.g., 300x200)<br />
                    • <a href="https://images.unsplash.com" target="_blank">Unsplash</a> - Right-click any image and select "Copy Image Address"
                </small>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
